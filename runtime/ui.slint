// runtime/ui.slint
import { Button, LineEdit, TextEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";

component StepRow inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    in property <bool> done;
    in property <color> accent;

    height: 44px;
    border-radius: 14px;
    background: active ? #162033 : #0f1726;

    HorizontalBox {
        padding: 10px;
        spacing: 10px;

        Rectangle {
            width: 24px;
            height: 24px;
            border-radius: 12px;
            background: root.done || root.active ? root.accent : #243146;

            Text {
                text: root.done ? "✓" : "";
                color: white;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
        }

        Text {
            text: root.label;
            color: root.active ? white : #9fb0ca;
            vertical-alignment: center;
            font-size: 15px;
        }
    }
}

export component InstallerWindow inherits Window {
    in-out property <string> app_name;
    in-out property <string> version_text;
    in-out property <string> publisher_text;
    in-out property <string> welcome_text;
    in-out property <string> license_text;
    in-out property <string> install_dir;
    in-out property <string> status_text;
    in-out property <string> detail_text;
    in-out property <string> error_text;
    in-out property <color> accent_color: #7c3aed;
    in-out property <bool> has_license: false;
    in-out property <bool> install_running: false;
    in-out property <int> current_screen: 0;
    in-out property <float> progress_value: 0;

    callback back();
    callback next();
    callback cancel();
    callback finish();

    title: app_name + " Setup";
    preferred-width: 960px;
    preferred-height: 620px;
    min-width: 920px;
    min-height: 600px;
    background: #0b1020;

    HorizontalBox {
        padding: 28px;
        spacing: 24px;

        Rectangle {
            width: 260px;
            border-radius: 24px;
            background: #101827;

            VerticalBox {
                padding: 24px;
                spacing: 18px;

                Rectangle {
                    height: 86px;
                    border-radius: 20px;
                    background: #141f33;

                    Rectangle {
                        x: 18px;
                        y: 18px;
                        width: 50px;
                        height: 50px;
                        border-radius: 16px;
                        background: root.accent_color;

                        Text {
                            text: "SW";
                            color: white;
                            font-size: 18px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    Text {
                        x: 82px;
                        y: 16px;
                        text: root.app_name;
                        color: white;
                        font-size: 22px;
                        font-weight: 700;
                    }

                    Text {
                        x: 82px;
                        y: 46px;
                        text: root.version_text;
                        color: #93a4bf;
                        font-size: 13px;
                    }
                }

                StepRow {
                    label: "Welcome";
                    active: root.current_screen == 0;
                    done: root.current_screen > 0;
                    accent: root.accent_color;
                }

                StepRow {
                    label: root.has_license ? "License" : "Review";
                    active: root.current_screen == 1;
                    done: root.current_screen > 1 || !root.has_license;
                    accent: root.accent_color;
                }

                StepRow {
                    label: "Install";
                    active: root.current_screen == 2;
                    done: root.current_screen > 2;
                    accent: root.accent_color;
                }

                StepRow {
                    label: "Finish";
                    active: root.current_screen == 3 || root.current_screen == 4;
                    done: root.current_screen == 3;
                    accent: root.accent_color;
                }

                Rectangle {
                    vertical-stretch: 1;
                    border-radius: 18px;
                    background: #0d1424;

                    VerticalBox {
                        padding: 18px;
                        spacing: 8px;

                        Text {
                            text: "Optimized for speed";
                            color: white;
                            font-size: 16px;
                            font-weight: 600;
                        }
                        Text {
                            text: "Embedded payload, direct streaming extraction, zero external tools.";
                            color: #93a4bf;
                            wrap: word-wrap;
                            font-size: 13px;
                        }
                    }
                }

                Text {
                    text: root.publisher_text;
                    color: #6f839f;
                    font-size: 12px;
                }
            }
        }

        Rectangle {
            border-radius: 24px;
            background: #101827;
            horizontal-stretch: 1;

            VerticalBox {
                padding: 28px;
                spacing: 18px;

                Rectangle {
                    height: 76px;
                    border-radius: 20px;
                    background: #0f1726;

                    Text {
                        x: 22px;
                        y: 16px;
                        text: root.status_text;
                        color: white;
                        font-size: 28px;
                        font-weight: 700;
                    }

                    Text {
                        x: 22px;
                        y: 48px;
                        width: parent.width - 44px;
                        text: root.detail_text;
                        color: #8ca0bc;
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                }

                if root.current_screen == 0 : Rectangle {
                    vertical-stretch: 1;
                    border-radius: 20px;
                    background: #0d1424;

                    VerticalBox {
                        padding: 24px;
                        spacing: 16px;

                        Text {
                            text: root.welcome_text;
                            color: white;
                            font-size: 30px;
                            font-weight: 700;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "SetupWeaver will unpack the embedded payload directly to disk and configure the machine only when needed.";
                            color: #9fb0ca;
                            wrap: word-wrap;
                            font-size: 15px;
                        }

                        Rectangle {
                            height: 1px;
                            background: #22314b;
                        }

                        Text {
                            text: "Install location";
                            color: white;
                            font-size: 14px;
                            font-weight: 600;
                        }

                        LineEdit {
                            text <=> root.install_dir;
                            enabled: !root.install_running;
                            horizontal-stretch: 1;
                        }

                        Rectangle {
                            border-radius: 18px;
                            background: #121c2f;
                            vertical-stretch: 1;

                            VerticalBox {
                                padding: 18px;
                                spacing: 10px;

                                Text {
                                    text: "What happens next";
                                    color: white;
                                    font-size: 16px;
                                    font-weight: 600;
                                }

                                Text {
                                    text: "• Files are extracted from a single self-contained setup.exe\n• Registry, PATH, and shortcuts are applied after extraction\n• No network access is performed unless you explicitly script it";
                                    color: #9fb0ca;
                                    wrap: word-wrap;
                                    font-size: 14px;
                                }
                            }
                        }
                    }
                }

                if root.current_screen == 1 : Rectangle {
                    vertical-stretch: 1;
                    border-radius: 20px;
                    background: #0d1424;

                    VerticalBox {
                        padding: 24px;
                        spacing: 12px;

                        Text {
                            text: "License agreement";
                            color: white;
                            font-size: 26px;
                            font-weight: 700;
                        }

                        TextEdit {
                            text: root.license_text;
                            read-only: true;
                            wrap: word-wrap;
                            vertical-stretch: 1;
                            horizontal-stretch: 1;
                        }
                    }
                }

                if root.current_screen == 2 : Rectangle {
                    vertical-stretch: 1;
                    border-radius: 20px;
                    background: #0d1424;

                    VerticalBox {
                        padding: 24px;
                        spacing: 18px;

                        Rectangle {
                            height: 14px;
                            border-radius: 999px;
                            background: #1a2537;

                            Rectangle {
                                width: parent.width * root.progress_value;
                                height: parent.height;
                                border-radius: 999px;
                                background: root.accent_color;
                            }
                        }

                        Text {
                            text: root.progress_value < 1.0 ? "Installing..." : "Finalizing...";
                            color: white;
                            font-size: 24px;
                            font-weight: 700;
                        }

                        Text {
                            text: root.detail_text;
                            color: #9fb0ca;
                            wrap: word-wrap;
                            font-size: 14px;
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            border-radius: 18px;
                            background: #121c2f;

                            VerticalBox {
                                padding: 18px;
                                spacing: 10px;

                                Text {
                                    text: "Why this stays fast";
                                    color: white;
                                    font-size: 16px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: "Sequential reads from the embedded archive keep HDD startup smooth, while the runtime avoids external helper processes during extraction.";
                                    color: #9fb0ca;
                                    wrap: word-wrap;
                                    font-size: 14px;
                                }
                            }
                        }
                    }
                }

                if root.current_screen == 3 : Rectangle {
                    vertical-stretch: 1;
                    border-radius: 20px;
                    background: #0d1424;

                    VerticalBox {
                        padding: 24px;
                        spacing: 16px;

                        Rectangle {
                            width: 64px;
                            height: 64px;
                            border-radius: 32px;
                            background: root.accent_color;

                            Text {
                                text: "✓";
                                color: white;
                                font-size: 30px;
                                font-weight: 800;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }

                        Text {
                            text: root.app_name + " is installed.";
                            color: white;
                            font-size: 30px;
                            font-weight: 700;
                        }

                        Text {
                            text: "You can close the installer now. Any finish actions configured by the package have already been launched.";
                            color: #9fb0ca;
                            wrap: word-wrap;
                            font-size: 15px;
                        }
                    }
                }

                if root.current_screen == 4 : Rectangle {
                    vertical-stretch: 1;
                    border-radius: 20px;
                    background: #23121a;

                    VerticalBox {
                        padding: 24px;
                        spacing: 16px;

                        Text {
                            text: "Something went wrong";
                            color: white;
                            font-size: 30px;
                            font-weight: 700;
                        }

                        TextEdit {
                            text: root.error_text;
                            read-only: true;
                            wrap: word-wrap;
                            vertical-stretch: 1;
                            horizontal-stretch: 1;
                        }
                    }
                }

                Rectangle {
                    height: 60px;
                    border-radius: 18px;
                    background: #0f1726;

                    HorizontalBox {
                        padding: 12px;
                        spacing: 10px;

                        Rectangle { horizontal-stretch: 1; }

                        if !root.install_running && (root.current_screen == 0 || root.current_screen == 1) : Button {
                            text: root.current_screen == 1 ? "Back" : "Cancel";
                            clicked => {
                                if root.current_screen == 1 {
                                    root.back();
                                } else {
                                    root.cancel();
                                }
                            }
                        }

                        if !root.install_running && (root.current_screen == 0 || root.current_screen == 1) : Button {
                            text: root.current_screen == 0 && root.has_license ? "Continue" : "Install";
                            clicked => { root.next(); }
                        }

                        if !root.install_running && (root.current_screen == 3 || root.current_screen == 4) : Button {
                            text: root.current_screen == 3 ? "Finish" : "Close";
                            clicked => { root.finish(); }
                        }
                    }
                }
            }
        }
    }
}
